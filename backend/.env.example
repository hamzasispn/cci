# ⚠️ This file is COMMITTED to git. Put PLACEHOLDERS only — never real secrets.
# Real values go in .env.local (gitignored) for local dev, and in Vercel for prod.

# Supabase
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Comma-separated list of allowed browser origins for /api/leads (your Webflow site)
ALLOWED_ORIGINS=https://www.coachabilityconsultants.com,https://coachabilityconsultants.com

# Resend (transactional email) — get from https://resend.com
RESEND_API_KEY=re_xxxxxxxx

# Admin dashboard password (choose a long, strong value)
ADMIN_PASSWORD=change-me-to-a-strong-password

# Google OAuth (Sheets sync) — from Google Cloud Console → Credentials
GOOGLE_CLIENT_ID=xxxxxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=xxxxxxxx
GOOGLE_REDIRECT_URI=https://cci-silk.vercel.app/api/google/callback
